                        ->where('is_draft', 0)->where('category.type', 0)->where('category.display_on_home', 1)->orderBy('total', 'desc')->groupBy('category.name')->limit(6)->get();
        $data['Destinations'] = \App\ExperienceCategory::select('category.*', DB::raw('count(experience_category.experience_id) as total'))
                        ->join("category", "category_id", "=", "category.id")
                        ->join("experiences", "experiences.id", "=", "experience_category.experience_id")
                        ->where('is_draft', 0)->where('category.type', 1)->where('category.display_on_home', 1)->orderBy('total', 'desc')->groupBy('category.name')->limit(8)->get();
        /*$data['featured_countries'] = \App\ExperienceCategory::select('category.*', DB::raw('count(experience_category.experience_id) as total'))
                        ->join("category", "category_id", "=", "category.id")
                        ->join("experiences", function($query) {
