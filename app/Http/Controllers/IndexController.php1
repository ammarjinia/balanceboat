                            $query->where("experiences.featured_countries", "=", 2);
                        })
                        ->where('is_draft', 0)->where('category.type', 1)->orderBy('total', 'desc')->groupBy('category.name')->limit(8)->get();
        $data['featured_cities'] = \App\ExperienceCategory::select('category.*', DB::raw('count(experience_category.experience_id) as total'))
                        ->join("category", "category_id", "=", "category.id")
                        ->join("experiences", function($query) {
